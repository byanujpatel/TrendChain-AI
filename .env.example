# Required for Claude-powered analysis. The app uses a local fallback without it.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required only for live YouTube collection.
YOUTUBE_API_KEY=

# Optional but recommended for live trending coins and categories.
COINGECKO_DEMO_API_KEY=

# Optional configuration.
DEFAULT_QUERY=crypto
DEFAULT_DAYS=30
MAX_ITEMS_PER_SOURCE=20
REQUEST_TIMEOUT_SECONDS=8
